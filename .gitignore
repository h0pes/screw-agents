# Design specs — working material consumed during planning, not committed
docs/specs/

# Research notes — local working material, not committed
docs/research/*
# Exception: benchmark research docs are canonical deliverables (Phase 0.5)
!docs/research/benchmark-*.md

# Phase working files — deferred-polish punchlists and session handoff docs
# are internal session state, not PR deliverables. Live on disk in the worktree
# for session continuity; not tracked in git.
docs/PHASE_*_PUNCHLIST.md
docs/PHASE_*_HANDOFF.md
docs/notes.txt

# Claude Code local settings (permissions, preferences — not committed)
.claude/settings.json

# Codex local scratch/state. Shared repo guidance lives in AGENTS.md instead.
.codex
.codex/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environments
.venv/
venv/
env/

# uv
.python-version

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.netrw*

# OS
.DS_Store
Thumbs.db

# Benchmark evaluation results (large, machine-generated)
benchmarks/results/

# Benchmark external datasets (large, downloaded, reproducible from manifests)
benchmarks/external/**
!benchmarks/external/.gitkeep
!benchmarks/external/manifests/
!benchmarks/external/manifests/**
# Derived manifests (large, reproducible via apply_dedup / apply_splits)
benchmarks/external/manifests/_deduplicated.manifest.json
benchmarks/external/manifests/_chrono_split.manifest.json
benchmarks/external/manifests/_cross_project_splits.manifest.json
# MoreFixes docker-compose is tracked; dump/ subdir (16 GB) is not
!benchmarks/external/morefixes/
!benchmarks/external/morefixes/docker-compose.yml

# flawgarden/reality-check vendor clone (pinned via manifest, not tracked)
benchmarks/cve-ingest/

# Project: per-project runtime state (generated by screw-agents in target repos)
.screw/

# Worktrees
.worktrees/

# Testing
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
